<?xml version="1.0"?>
<!--
  Simulated Intel RealSense D435i camera macro for the Unitree G1.
  Matches D435i specs:
    - RGB: 69.4° HFOV, 640x480 @ 30fps
    - Depth: 87° HFOV, 640x480 @ 30fps
    - Range: 0.3m – 10m
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="g1_camera" params="parent_link xyz:='0.05 0.0 0.12' rpy:='0 0 0'">

    <!-- Camera body link -->
    <link name="camera_link">
      <visual>
        <geometry>
          <box size="0.09 0.025 0.025"/>
        </geometry>
        <material name="camera_silver">
          <color rgba="0.7 0.7 0.7 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <box size="0.09 0.025 0.025"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.072"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <!-- Optical frame (Z-forward convention for camera data) -->
    <link name="camera_optical_link"/>
    <joint name="camera_optical_joint" type="fixed">
      <parent link="camera_link"/>
      <child link="camera_optical_link"/>
      <!-- Rotate from URDF convention (X-fwd) to optical (Z-fwd) -->
      <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
    </joint>

    <!-- Fixed joint: mount camera on parent (head/torso) -->
    <joint name="camera_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="camera_link"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
    </joint>

    <!-- Gazebo RGB camera sensor -->
    <gazebo reference="camera_link">
      <sensor name="d435i_rgb" type="camera">
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>30</update_rate>
        <topic>camera/color/image_raw</topic>
        <gz_frame_id>camera_optical_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.2112</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.3</near>
            <far>10.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>

    <!-- Gazebo depth camera sensor -->
    <gazebo reference="camera_link">
      <sensor name="d435i_depth" type="depth_camera">
        <always_on>true</always_on>
        <visualize>false</visualize>
        <update_rate>30</update_rate>
        <topic>camera/depth/image_rect_raw</topic>
        <gz_frame_id>camera_optical_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.5184</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R_FLOAT32</format>
          </image>
          <clip>
            <near>0.3</near>
            <far>10.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.005</stddev>
          </noise>
        </camera>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>
